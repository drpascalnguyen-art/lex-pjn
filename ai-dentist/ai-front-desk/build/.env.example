# Copy to .env and fill in. Never commit .env.
PORT=3000

# Anthropic (sign BAA before real patient traffic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Twilio (sign BAA; use HIPAA-eligible products only)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_NUMBER=+1503...

# Where staff alerts / leads / messages go (front desk cell or shared line)
STAFF_ALERT_PHONE=+1503...
# On-call provider for emergency escalation
ON_CALL_PHONE=+1503...

# Practice facts injected into the SMS prompt
PRACTICE_NAME=Your Practice Name
CITY=Portland
OFFICE_HOURS=Mon-Thu 8am-5pm
ADDRESS=123 Main St, Portland, OR

# Shared secret you configure on Retell webhooks (optional but recommended)
RETELL_WEBHOOK_SECRET=
