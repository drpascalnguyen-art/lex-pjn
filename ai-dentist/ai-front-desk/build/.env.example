# Copy to .env and fill in. Never commit .env.
PORT=3000

# Anthropic (sign BAA before real patient traffic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Twilio (sign BAA; use HIPAA-eligible products only)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_NUMBER=+19713856800

# Where staff alerts / leads / messages / URGENT flags go (front desk cell or shared line)
STAFF_ALERT_PHONE=+1503...

# Practice facts injected into the SMS prompt
PRACTICE_NAME=PJN Dental
CITY=Beaverton
OFFICE_HOURS=Mon/Tue/Wed 7am-7pm
ADDRESS=17535 SW Tualatin Valley Hwy, Beaverton, OR 97003

# Shared secret you configure on Retell webhooks (optional but recommended)
RETELL_WEBHOOK_SECRET=
